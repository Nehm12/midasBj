      "pkceCodeChallengeMethod": "S256",
      "redirectUris": ["midasbenin://callback", "http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "directAccessGrantsEnabled": true,
      "attributes": {
        "post.logout.redirect.uris": "midasbenin://callback"
      }
    },
    {
      "clientId": "apdp-console",
      "enabled": true,
      "publicClient": false,
