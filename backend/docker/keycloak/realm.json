{
  "realm": "midas-benin",
  "displayName": "MIDAS-Bénin",
  "displayNameHtml": "<div class=\"kc-logo-text\"><span>MIDAS-Bénin</span></div>",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": false,
  "bruteForceProtected": true,
  "rememberMe": true,
  "passwordPolicy": "length(8) and digits(1) and lowerCase(1) and upperCase(1)",
  "roles": {
    "realm": [
      { "name": "citizen", "description": "Citoyen béninois - droit de consulter ses propres données" },
      { "name": "iot_operator", "description": "Opérateur IoT - peut gérer les appareils connectés" },
      { "name": "apdp_inspector", "description": "Inspecteur APDP - droit de consulter les pistes d'audit" },
      { "name": "vc_issuer", "description": "Émetteur de credentials - ANIP, CNA, Universités" },
      { "name": "admin", "description": "Administrateur système MIDAS" }
    ]
  },
